# Copy this file to .env.local and fill with your real credentials.
# Do not commit .env.local to version control.

# Postgres connection string (docker-compose default shown — port 5433 avoids macOS Postgres conflict)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/dungeoncrawler

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Optional: controlled visual asset generation.
# Never commit a real key. Use a project-level budget cap in the OpenAI dashboard too.
OPENAI_API_KEY=sk-your-openai-api-key
ASSET_GEN_MAX_COST_USD=5
ASSET_GEN_MODEL=gpt-image-2
ASSET_GEN_QUALITY=medium
