# Copy this file to .env.local and fill with your real credentials.
# Do not commit .env.local to version control.

# Postgres connection string (docker-compose default shown)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dungeoncrawler

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Groq API key
GROQ_API_KEY=your-groq-api-key
